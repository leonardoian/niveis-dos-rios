# Neon PostgreSQL — connection string do painel do Neon
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Credenciais da API HidroWebService da ANA
# Solicitar cadastro em: https://www.ana.gov.br/hidrowebservice
ANA_IDENTIFICADOR=seu_identificador_aqui
ANA_SENHA=sua_senha_aqui

# Segredo para proteger o endpoint do cron (qualquer string aleatória)
# A Vercel envia automaticamente esse header nas chamadas de cron
CRON_SECRET=gere_uma_string_aleatoria_segura
